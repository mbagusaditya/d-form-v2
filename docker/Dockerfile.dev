FROM dunglas/frankenphp:php8.3-alpine

ARG UID=1000
ARG GID=1000

# Install required PHP extensions
RUN install-php-extensions \
    pcntl \
    zip \
    bcmath \
    intl \
    imagick \
    pdo_mysql \
    redis

# Install Node.js and npm for frontend build (LTS version)
RUN apk add --no-cache nodejs npm

# Install Composer (if not already available)
RUN if ! command -v composer &> /dev/null; then \
        curl -sS https://getcomposer.org/installer | php -- --install-dir=/usr/local/bin --filename=composer; \
    fi

# Create app directory
WORKDIR /app

# Create appuser with proper permissions
# Use numeric IDs that work on both Linux and Windows Docker
# Try to create group and user, ignore errors if they already exist
RUN addgroup -g $GID -S appuser || true && \
    adduser -u $UID -G appuser -s /bin/sh -D -S appuser || true

# Copy entrypoint script
COPY docker/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

# Set working directory ownership (will be overridden by volume mounts, but helps with initial setup)
RUN chown -R appuser:appuser /app 2>/dev/null || true

# Switch to appuser for running commands
USER appuser

# Set entrypoint
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]

# Default command for development
CMD ["--watch", "--workers=1", "--max-requests=1"]
